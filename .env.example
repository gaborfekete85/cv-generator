# Copy to `.env` and fill in real values. Never commit `.env`.

# --- Clerk authentication ---
# Publishable key is safe to expose to the browser (ships in HTML).
# Secret key MUST stay server-side — it's reserved for future backend calls
# to Clerk's API (user listing, orgs, etc.). Leave both empty to DISABLE auth
# (app becomes openly accessible, useful for local dev without Clerk).
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- CV generator config ---
# auto  → use WeasyPrint if its native libs are available, else xhtml2pdf
# xhtml2pdf → force the pure-Python backend
# weasyprint → force WeasyPrint (errors if libs missing)
CV_PDF_BACKEND=auto

# Set to "none" to suppress the "Core stack:" line at the end of the CV summary.
# CV_SUMMARY_STACK=on
